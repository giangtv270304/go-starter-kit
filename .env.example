# ===================================
# Common Settings
# ===================================
GRACEFUL_SHUTDOWN_PERIOD=30s

# ===================================
# Global Log Settings
# ===================================
LOG_LEVEL=debug

# ===================================
# Metric Server Settings
# ===================================
METRIC_SERVER_HOST=0.0.0.0
METRIC_SERVER_PORT=9192
METRIC_SERVER_READ_TIMEOUT=30s
METRIC_SERVER_WRITE_TIMEOUT=30s

# ===================================
# HTTP Server Settings
# ===================================
HTTP_SERVER_HOST=0.0.0.0
HTTP_SERVER_PORT=9190
HTTP_SERVER_READ_TIMEOUT=60s
HTTP_SERVER_WRITE_TIMEOUT=60s
HTTP_ENABLE_CORS=true
HTTP_BODY_LIMIT=100K
HTTP_SKIP_REQUEST_ID=true

# ===================================
# Postgres Configuration
# ===================================
POSTGRES_URL=postgresql://go_starter_kit:<SECRET>@0.0.0.0:5432/go_starter_kit
POSTGRES_MAX_CONNECTION=2
POSTGRES_MIN_CONNECTION=1
POSTGRES_MAX_CONNECTION_IDLE_TIME=4m
POSTGRES_PING_TIMEOUT=30s
POSTGRES_LOG_LEVEL=trace

# ===================================
# Migration Settings
# ===================================
MIGRATION_ENABLED=false
MIGRATION_SOURCE=file://db/migrations

# ===================================
# Valkey Configuration
# ===================================
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=password
VALKEY_DB=0
VALKEY_MAX_IDLE_CONNS=0
VALKEY_MIN_IDLE_CONNS=0
VALKEY_PING_TIMEOUT=30s
VALKEY_DIAL_TIMEOUT=30s
VALKEY_SERVER_READ_TIMEOUT=30s
VALKEY_SERVER_WRITE_TIMEOUT=30s
VALKEY_POOL_SIZE=1
VALKEY_CONSUMER_GROUP=api-key-service

# ===================================
# Docker Compose Configuration
# ===================================
DB_PASSWORD=<SECRET>
